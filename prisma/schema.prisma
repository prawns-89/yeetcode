generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TypingSession {
  id           String   @id @default(cuid())
  snippetId    String
  snippetTitle String
  mode         String
  netWpm       Int
  rawWpm       Int
  accuracy     Int
  secondsTaken Int
  errors       Int      @default(0)
  completed    Boolean  @default(true)
  attemptedAt  DateTime @default(now())

  @@index([attemptedAt(sort: Desc)])
}

model PersonalBest {
  snippetId    String   @id
  snippetTitle String   @default("")
  bestNetWpm   Int
  bestAccuracy Int
  achievedAt   DateTime
  sessionId    String?
}

model CurriculumProgress {
  snippetId        String   @id
  firstCompletedAt DateTime
  attemptCount     Int      @default(1)
  lastNetWpm       Int
  lastAccuracy     Int
}
